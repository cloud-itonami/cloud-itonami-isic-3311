{:itonami.blueprint/id "cloud-itonami-isic-3311"
 :itonami.blueprint/name "Repair of Fabricated Metal Products"
 :itonami.blueprint/isic-rev5 "3311"
 :itonami.blueprint/domain :manufacturing/fabricated-metal-repair
 :itonami.blueprint/license "AGPL-3.0-or-later"
 :itonami.blueprint/social-impact [:worker-safety :repair-access :circular-economy-repair-over-replace]
 :itonami.blueprint/governor :fabricated-metal-repair-governor
 :itonami.blueprint/robotics false
 :itonami.blueprint/required-technologies [:identity :forms :audit-ledger]
